# Modern Spring Boot + React Project GitIgnore

# Target directory (Maven builds)
target/
**/target/

# Node modules (Frontend dependencies)
node_modules/
**/node_modules/

# Production builds (React builds)
dist/
**/dist/

# IDE and Editor Files
.idea/
**/.idea/
*.iml
**/*.iml
.vscode/
**/.vscode/
.settings/
.classpath
.project
.factorypath
nb-configuration.xml
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Log files
*.log
logs/

# Local configuration / Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Backups
old_servlet_backup/
*.bak
